generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Location {
  id        Int      @id @default(autoincrement())
  city      String   @unique
  state     String
  slug      String   @unique
  lat       Float?
  lng       Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  pages     Page[]
}

model Service {
  id          Int         @id @default(autoincrement())
  name        String
  slug        String      @unique
  cluster     String
  parentSlug  String?
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  pages       Page[]
  caseStudies CaseStudy[]
}

model Page {
  id           Int       @id @default(autoincrement())
  slug         String    @unique
  pageType     String
  status       String    @default("draft")
  title        String
  metaDesc     String?
  h1           String?
  canonical    String?
  ogTitle      String?
  ogDesc       String?
  ogImage      String?
  primaryKw    String?
  secondaryKws String[]  @default([])
  bodyJson     Json?
  layoutHtml   String?
  layoutCss    String?
  layoutJson   Json?
  useLayout    Boolean   @default(false)
  serviceId    Int?
  service      Service?  @relation(fields: [serviceId], references: [id])
  locationId   Int?
  location     Location? @relation(fields: [locationId], references: [id])
  aiGenerated  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  aiJobs       AiJob[]
}

model BlogPost {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  status        String    @default("draft")
  title         String
  metaDesc      String?
  primaryKw     String?
  secondaryKws  String[]  @default([])
  excerpt       String?
  bodyMd        String?
  layoutHtml    String?
  layoutCss     String?
  layoutJson    Json?
  useLayout     Boolean   @default(false)
  category      String?
  tags          String[]  @default([])
  featuredImage String?
  authorName    String?
  aiGenerated   Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CaseStudy {
  id                 Int       @id @default(autoincrement())
  slug               String    @unique
  status             String    @default("draft")
  clientName         String
  clientAlias        String?
  industry           String
  platform           String
  city               String?
  engagementDuration String?
  year               Int?
  serviceId          Int?
  service            Service?  @relation(fields: [serviceId], references: [id])
  primaryMetric      String
  primaryDelta       String
  secondaryMetric    String?
  secondaryDelta     String?
  thirdMetric        String?
  thirdDelta         String?
  timeToResult       String?
  challenge          String?
  approach           String?
  keyInsight         String?
  clientQuote        String?
  clientQuoteAuthor  String?
  title              String?
  metaDesc           String?
  primaryKw          String?
  featuredImage      String?
  featuredHome       Boolean   @default(false)
  featuredService    Boolean   @default(false)
  layoutHtml         String?
  layoutCss          String?
  layoutJson         Json?
  useLayout          Boolean   @default(false)
  aiGenerated        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Media {
  id           Int      @id @default(autoincrement())
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  alt          String?
  uploadedBy   String?
  createdAt    DateTime @default(now())
}

model AiJob {
  id        Int      @id @default(autoincrement())
  pageId    Int?
  page      Page?    @relation(fields: [pageId], references: [id])
  jobType   String
  status    String   @default("pending")
  prompt    String?
  resultLog String?
  errorLog  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("editor")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
